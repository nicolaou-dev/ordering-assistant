# Build-time config for the storefront. Copy to .env and fill in.
# The catalog and images are baked into the build from these — no runtime fetch.

# Neon connection, read-only loop_agent role (catalog read at build time).
DATABASE_URL=postgresql://loop_agent:...@host/db

# Shop's phone_number_id — scopes the catalog read under RLS. The shop's name,
# cover and tagline are read from the shops row by this id at build time.
SHOP_ID=1098392886696367

# Base URL of the Worker serving /cart/* (the only runtime calls).
WORKER_URL=http://localhost:8787

# Shop's dialable E.164 number for the wa.me checkout handoff.
WA_NUMBER=0000000000
