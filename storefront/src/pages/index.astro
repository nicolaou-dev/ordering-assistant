---
import { Image, getImage } from "astro:assets";
import { loadCatalog, loadShop } from "../lib/catalog";
import { money } from "../lib/money";
import CartControl from "../components/CartControl.tsx";
import Cart from "../components/Cart.tsx";
import RecentItems from "../components/RecentItems.tsx";
import TokenNotice from "../components/TokenNotice.tsx";
import "../styles/global.css";

const categories = await loadCatalog();
const shop = await loadShop();
const workerUrl = import.meta.env.WORKER_URL ?? "";
const waNumber = import.meta.env.WA_NUMBER ?? "";
const shopName = shop.name;
const shopCover = shop.cover_url;
const shopTagline = shop.tagline;

// Anchor-id slug for each category, so the pills jump to their section.
const slug = (s: string) =>
  s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");

// product_id -> optimized thumbnail, for the cart island (cart items carry no
// image). Same width/height as the grid <Image>, so the transform is reused.
const thumbs: Record<string, string> = {};
for (const cat of categories) {
  for (const sub of cat.subcategories) {
    for (const p of sub.products) {
      if (p.image_url) {
        thumbs[p.product_id] = (
          await getImage({ src: p.image_url, width: 320, height: 180 })
        ).src;
      }
    }
  }
}

// Search index emitted inline — no network fetch needed at runtime.
// Includes price + thumb so the search overlay can render full cards.
const searchIndex = categories.flatMap((cat) =>
  cat.subcategories.flatMap((sub) =>
    sub.products.map((p) => ({
      i: p.product_id,
      n: p.name,
      d: p.description ?? "",
      c: p.category,
      p: p.price_minor,
      cur: p.currency,
      img: thumbs[p.product_id] ?? null, // thumbnail — used in search results
      src: p.image_url ?? null,           // original — used in product overlay
      stock: p.in_stock,
    })),
  ),
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{shopName}</title>
	</head>
	<body class="bg-neutral-950 text-neutral-50">
		<header class="h-44 overflow-hidden bg-neutral-900 sm:h-56">
			{shopCover && (
				<img
					src={shopCover}
					alt={shopName}
					class="h-full w-full object-cover"
				/>
			)}
		</header>

		{/* Shop identity */}
		<div class="mx-auto max-w-2xl px-4 pt-4">
			<h1 class="text-2xl font-extrabold tracking-tight">{shopName}</h1>
			{shopTagline && (
				<p class="mt-1 text-sm text-neutral-400">{shopTagline}</p>
			)}
		</div>

		<div class="mx-auto max-w-2xl px-4 pb-28">
			<TokenNotice client:load />

			<RecentItems client:load workerUrl={workerUrl} images={thumbs} />

			{/* Inline search index — Fuse reads this at runtime, no fetch needed */}
			<script type="application/json" id="search-index" set:html={JSON.stringify(searchIndex)} />

			{
				categories.length > 1 && (
					<div
						id="nav"
						class="sticky top-0 z-20 -mx-4 mb-5 bg-neutral-950/95 backdrop-blur"
					>
						{/* Search */}
						<div class="px-4 pt-3">
							<button class="js-search-open flex w-full items-center gap-2 rounded-full bg-neutral-800 px-4 py-3 text-left text-neutral-500">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
									<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
								</svg>
								<span class="text-sm">Search products…</span>
							</button>
						</div>
						{/* Categories: underline tabs, always visible. */}
						<div class="flex gap-5 overflow-x-auto px-4 pt-3">
							{categories.map((cat) => (
								<a
									href={`#cat-${slug(cat.name)}`}
									data-spy="top"
									class="cat-tab shrink-0 whitespace-nowrap border-b-2 border-transparent pb-2 text-sm font-medium text-neutral-500 transition-colors"
								>
									{cat.name}
								</a>
							))}
						</div>
						{/* Subcategories: plain text that appears once you scroll; the one
						    you're scrolled to is auto-selected as an opaque pill, and
						    tapping one jumps to it. One group per category; the script
						    shows the active category's. */}
						<div id="sub-bar" class="border-t border-white/10">
							{categories.map((cat) => {
								const brands = cat.subcategories.filter((s) => s.name);
								return brands.length > 0 ? (
									<div data-subbar={slug(cat.name)} class="hidden">
										<div class="flex gap-1.5 overflow-x-auto px-4 py-2">
											{brands.map((sub) => (
												<a
													href={`#cat-${slug(cat.name)}-${slug(sub.name!)}`}
													data-spy="sub"
													class="sub-opt shrink-0 whitespace-nowrap rounded-full px-3.5 py-1.5 text-sm font-medium text-neutral-500"
												>
													{sub.name}
												</a>
											))}
										</div>
									</div>
								) : null;
							})}
						</div>
					</div>
				)
			}

			{
				categories.map((cat) => (
					<section id={`cat-${slug(cat.name)}`} class="mb-8 scroll-mt-24">
						<h2 class="mb-3 text-lg font-bold">{cat.name}</h2>
						{cat.subcategories.map((sub) => (
							<div
								id={sub.name ? `cat-${slug(cat.name)}-${slug(sub.name)}` : undefined}
								data-subsection={sub.name ? "" : undefined}
								class="mb-5 scroll-mt-28 last:mb-0"
							>
								{sub.name && (
									<h3 class="mb-1.5 text-xs font-semibold uppercase tracking-wide text-neutral-400">
										{sub.name}
									</h3>
								)}
								<div class="divide-y divide-white/10 sm:grid sm:grid-cols-2 sm:gap-3 sm:divide-y-0">
									{sub.products.map((p) => (
										<article data-product-id={p.product_id} class="flex cursor-pointer gap-3 py-4 sm:rounded-2xl sm:bg-neutral-900 sm:px-3 sm:py-3">
											<div class="flex min-w-0 flex-1 flex-col items-start">
												<h4 class="text-sm font-semibold leading-snug">{p.name}</h4>
												{p.description && (
													<p class="mt-1 line-clamp-2 text-xs text-neutral-400">
														{p.description}
													</p>
												)}
												<span class="mt-2 text-sm font-bold">
													{money(p.price_minor, p.currency)}
												</span>
												<div class="mt-2" data-cart-area>
													<CartControl
														client:visible
														productId={p.product_id}
														name={p.name}
														workerUrl={workerUrl}
														soldOut={!p.in_stock}
													/>
												</div>
											</div>
											{p.image_url && (
												<Image
													src={p.image_url}
													alt={p.name}
													width={320}
													height={180}
													loading="lazy"
													class="h-24 w-24 shrink-0 self-center rounded-xl object-cover"
												/>
											)}
										</article>
									))}
								</div>
							</div>
						))}
					</section>
				))
			}
		</div>

		<Cart client:load workerUrl={workerUrl} waNumber={waNumber} images={thumbs} />

		{/* Full-screen product detail overlay */}
		<div id="product-page" data-worker-url={workerUrl} style="display:none" class="fixed inset-0 z-50 flex flex-col bg-neutral-950">
			<div class="flex items-center gap-1 border-b border-white/10 px-2 py-2">
				<button id="product-back" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-neutral-400 active:bg-neutral-800">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="m15 18-6-6 6-6"/>
					</svg>
				</button>
				<span id="product-category" class="flex-1 truncate text-sm text-neutral-500"></span>
			</div>
			<div class="flex-1 overflow-y-auto">
				<div class="aspect-video w-full bg-neutral-900">
					<img id="product-img" class="h-full w-full object-cover" alt="" />
				</div>
				<div class="px-4 py-5">
					<h2 id="product-name" class="text-xl font-bold leading-snug"></h2>
					<div id="product-price" class="mt-1 text-lg font-bold"></div>
					<p id="product-desc" class="mt-3 text-sm leading-relaxed text-neutral-400"></p>
					<div id="product-cart" class="mt-5"></div>
				</div>
			</div>
		</div>

		{/* Full-screen search overlay — shown/hidden via JS, uses pushState for back button */}
		<div id="search-page" style="display:none" class="fixed inset-0 z-50 flex flex-col bg-neutral-950">
			<div class="flex items-center gap-1 border-b border-white/10 px-2 py-2">
				<button id="search-back" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-neutral-400 active:bg-neutral-800">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="m15 18-6-6 6-6"/>
					</svg>
				</button>
				<input
					id="search-input"
					type="search"
					placeholder="Search products…"
					autocomplete="off"
					autocorrect="off"
					spellcheck="false"
					autofocus
					class="flex-1 bg-transparent text-base text-neutral-100 placeholder-neutral-500 outline-none"
					style="font-size:16px"
				/>
				<button id="search-clear" style="display:none" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-neutral-400 active:bg-neutral-800">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/>
					</svg>
				</button>
			</div>
			<div id="search-results" class="flex-1 overflow-y-auto px-4">
			</div>
		</div>

		<style>
			/* Active category: soft-blue underlined tab. */
			.cat-tab.is-active {
				color: #7ea6e0;
				border-bottom-color: #7ea6e0;
			}
			/* Selected subcategory: a faint translucent pill among plain-text options. */
			.sub-opt.is-active {
				background-color: rgba(126, 166, 224, 0.1);
				color: #bcd3f2;
			}
		</style>

		<script>
			const nav = document.getElementById("nav");
			if (nav) {
				const hrefId = (a: HTMLAnchorElement) =>
					decodeURIComponent(a.getAttribute("href")!.slice(1));
				const tabs = Array.from(
					nav.querySelectorAll<HTMLAnchorElement>('a[data-spy="top"]'),
				);
				const subBar = document.getElementById("sub-bar");
				const subGroups = Array.from(
					nav.querySelectorAll<HTMLElement>("[data-subbar]"),
				);
				const sections = Array.from(
					document.querySelectorAll<HTMLElement>('section[id^="cat-"]'),
				);

				// Slide a tab's horizontal bar so the active tab is centred in view.
				const reveal = (tab: HTMLElement) => {
					const row = tab.parentElement;
					if (!row) return;
					const left =
						tab.getBoundingClientRect().left -
						row.getBoundingClientRect().left +
						row.scrollLeft;
					row.scrollTo({
						left: left - row.clientWidth / 2 + tab.clientWidth / 2,
						behavior: "smooth",
					});
				};

				const subPills = Array.from(
					nav.querySelectorAll<HTMLAnchorElement>('a[data-spy="sub"]'),
				);
				const subSections = Array.from(
					document.querySelectorAll<HTMLElement>("[data-subsection]"),
				).filter((el) => el.id);

				// The lowest target whose top has scrolled above the marker line — the
				// category/brand you're currently reading.
				const lastAbove = (els: HTMLElement[], trigger: number) => {
					let best: HTMLElement | null = els[0] ?? null;
					for (const el of els) {
						if (el.getBoundingClientRect().top - trigger <= 0) best = el;
					}
					return best;
				};

				let curTop: string | null = null;
				let curSub: string | null = null;
				const sync = () => {
					const top = lastAbove(sections, 110);
					if (top && top.id !== curTop) {
						curTop = top.id;
						const cat = top.id.replace(/^cat-/, "");
						for (const a of tabs) {
							const on = hrefId(a) === top.id;
							a.classList.toggle("is-active", on);
							if (on) reveal(a);
						}
						for (const g of subGroups)
							g.classList.toggle("hidden", g.dataset.subbar !== cat);
					}

					// Auto-select the subcategory (brand) you're scrolled to.
					const sub = lastAbove(subSections, 150);
					const subId = sub ? sub.id : null;
					if (subId !== curSub) {
						curSub = subId;
						for (const a of subPills) {
							const on = subId !== null && hrefId(a) === subId;
							a.classList.toggle("is-active", on);
							if (on) reveal(a);
						}
					}
				};

				let raf = 0;
				addEventListener(
					"scroll",
					() => {
						if (!raf)
							raf = requestAnimationFrame(() => {
								raf = 0;
								sync();
							});
					},
					{ passive: true },
				);
				addEventListener("resize", sync, { passive: true });
				sync();
			}
		</script>

		<script>
			import Fuse from "fuse.js";
			import posthog from "../lib/posthog.js";

			type Entry = { i: string; n: string; d: string; c: string; p: number; cur: string; img: string | null };

			const raw = document.getElementById("search-index")?.textContent ?? "[]";
			const index: Entry[] = JSON.parse(raw);

			const fuse = new Fuse(index, {
				keys: ["n", "d", "c"],
				threshold: 0.35,
				ignoreLocation: true,
			});

			const overlay  = document.getElementById("search-page") as HTMLElement;
			const input    = document.getElementById("search-input") as HTMLInputElement;
			const clearBtn = document.getElementById("search-clear") as HTMLElement;
			const results  = document.getElementById("search-results") as HTMLElement;

			function openSearch() {
				overlay.style.display = "flex";
				history.pushState({ search: true }, "");
				input.focus();
			}

			function closeSearch() {
				overlay.style.display = "none";
				input.value = "";
				clearBtn.style.display = "none";
				results.innerHTML = "";
			}

			document.querySelectorAll<HTMLElement>(".js-search-open").forEach((btn) =>
				btn.addEventListener("click", openSearch),
			);
			document.getElementById("search-back")?.addEventListener("click", () => history.back());
			window.addEventListener("popstate", (e: PopStateEvent) => {
				const state = e.state as { search?: boolean; product?: string } | null;
				if (!state?.search && !state?.product) closeSearch();
			});

			clearBtn.addEventListener("click", () => {
				input.value = "";
				clearBtn.style.display = "none";
				results.innerHTML = "";
				input.focus();
			});

			function fmt(minor: number, cur: string) {
				return new Intl.NumberFormat("en-CY", { style: "currency", currency: cur }).format(minor / 100);
			}

			input.addEventListener("input", () => {
				const q = input.value.trim();
				clearBtn.style.display = q ? "flex" : "none";
				renderResults(q);
			});

			function renderResults(q: string) {
				results.innerHTML = "";
				if (!q) return;

				const hits = fuse.search(q, { limit: 50 });
				if (hits.length > 0) {
					posthog.capture("search_performed", { query: q, results_count: hits.length });
				}
				if (hits.length === 0) {
					const msg = document.createElement("p");
					msg.className = "py-10 text-center text-sm text-neutral-500";
					msg.textContent = `No results for "${q}"`;
					results.appendChild(msg);
					return;
				}

				for (const { item } of hits) {
					const art = document.createElement("article");
					art.className = "flex cursor-pointer gap-3 border-b border-white/10 py-4 active:bg-neutral-900";

					if (item.img) {
						const img = document.createElement("img");
						img.src = item.img;
						img.alt = item.n;
						img.className = "h-16 w-16 shrink-0 self-center rounded-xl object-cover";
						img.loading = "lazy";
						art.appendChild(img);
					}

					const info = document.createElement("div");
					info.className = "min-w-0 flex-1 self-center";

					const name = document.createElement("div");
					name.className = "text-sm font-semibold leading-snug";
					name.textContent = item.n;

					const cat = document.createElement("div");
					cat.className = "mt-0.5 text-xs text-neutral-500";
					cat.textContent = item.c;

					const price = document.createElement("div");
					price.className = "mt-1 text-sm font-bold";
					price.textContent = fmt(item.p, item.cur);

					info.append(name, cat, price);
					art.appendChild(info);

					art.addEventListener("click", () => {
						history.back();
						// Small delay to let the overlay close before scrolling
						setTimeout(() => {
							const target = document.querySelector<HTMLElement>(
								`[data-product-id="${CSS.escape(item.i)}"]`,
							);
							target?.scrollIntoView({ behavior: "smooth", block: "center" });
						}, 80);
					});

					results.appendChild(art);
				}
			}
		</script>
		<script>
			import { $cart, $pending, mutate, qtyOf, getToken } from "../lib/cart";
			import posthog from "../lib/posthog.js";

			type Entry = { i: string; n: string; d: string; c: string; p: number; cur: string; img: string | null; src: string | null; stock: boolean };

			const raw = document.getElementById("search-index")?.textContent ?? "[]";
			const byId = new Map<string, Entry>(
				(JSON.parse(raw) as Entry[]).map((e) => [e.i, e]),
			);

			const overlay  = document.getElementById("product-page") as HTMLElement;
			const workerUrl = overlay.dataset.workerUrl ?? "";
			const imgEl    = document.getElementById("product-img") as HTMLImageElement;
			const catEl    = document.getElementById("product-category") as HTMLElement;
			const nameEl   = document.getElementById("product-name") as HTMLElement;
			const priceEl  = document.getElementById("product-price") as HTMLElement;
			const descEl   = document.getElementById("product-desc") as HTMLElement;
			const cartEl   = document.getElementById("product-cart") as HTMLElement;

			let current: Entry | null = null;

			function fmt(minor: number, cur: string) {
				return new Intl.NumberFormat("en-CY", { style: "currency", currency: cur }).format(minor / 100);
			}

			function renderCartControl() {
				if (!current) return;
				const item = current;
				const token = getToken();
				cartEl.innerHTML = "";
				if (!token) return;

				if (!item.stock) {
					const badge = document.createElement("span");
					badge.className = "rounded-full bg-white/10 px-3 py-1.5 text-sm font-medium text-neutral-400";
					badge.textContent = "Sold out";
					cartEl.appendChild(badge);
					return;
				}

				const qty = qtyOf($cart.get(), item.i);
				const busy = $pending.get().has(item.i);

				if (qty > 0) {
					const wrap = document.createElement("div");
					wrap.className = "inline-flex items-center gap-1 rounded-full bg-[#0070d8] text-white";

					const remove = document.createElement("button");
					remove.disabled = busy;
					remove.className = "flex h-10 w-10 items-center justify-center rounded-full disabled:opacity-40";
					remove.innerHTML = qty === 1
						? `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>`
						: `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>`;
					remove.addEventListener("click", () => mutate(workerUrl, item.i, "remove"));

					const count = document.createElement("span");
					count.className = "min-w-6 text-center text-sm font-bold tabular-nums";
					count.textContent = String(qty);

					const add = document.createElement("button");
					add.disabled = busy;
					add.className = "flex h-10 w-10 items-center justify-center rounded-full disabled:opacity-40";
					add.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`;
					add.addEventListener("click", () => mutate(workerUrl, item.i, "add"));

					wrap.append(remove, count, add);
					cartEl.appendChild(wrap);
				} else {
					const btn = document.createElement("button");
					btn.disabled = busy;
					btn.className = "rounded-full bg-[#0070d8] px-6 py-2.5 text-sm font-semibold text-white disabled:opacity-40";
					btn.textContent = "Add to cart";
					btn.addEventListener("click", () => mutate(workerUrl, item.i, "add"));
					cartEl.appendChild(btn);
				}
			}

			// Keep cart control in sync with the store
			$cart.subscribe(renderCartControl);
			$pending.subscribe(renderCartControl);

			function openProduct(id: string) {
				const item = byId.get(id);
				if (!item) return;
				current = item;

				posthog.capture("product_detail_viewed", {
					product_id: id,
					product_name: item.n,
					category: item.c,
					price_minor: item.p,
					currency: item.cur,
				});

				catEl.textContent = item.c;
				nameEl.textContent = item.n;
				priceEl.textContent = fmt(item.p, item.cur);
				descEl.textContent = item.d;
				descEl.style.display = item.d ? "" : "none";

				if (item.src) {
					imgEl.src = item.src;
					imgEl.parentElement!.style.display = "";
				} else {
					imgEl.src = "";
					imgEl.parentElement!.style.display = "none";
				}

				renderCartControl();
				overlay.style.display = "flex";
				history.pushState({ product: id }, "");
			}

			function closeProduct() {
				overlay.style.display = "none";
				current = null;
			}

			document.getElementById("product-back")?.addEventListener("click", () => history.back());
			window.addEventListener("popstate", (e: PopStateEvent) => {
				const state = e.state as { product?: string; search?: boolean } | null;
				if (!state?.product && !state?.search) closeProduct();
			});

			// Open overlay on card tap, but not when tapping the cart control area
			document.addEventListener("click", (e) => {
				const article = (e.target as Element).closest("article[data-product-id]");
				if (!article) return;
				if ((e.target as Element).closest("[data-cart-area]")) return;
				openProduct((article as HTMLElement).dataset.productId!);
			});
		</script>
	</body>
</html>
