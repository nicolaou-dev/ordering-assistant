{
  "name": "worker",
  "type": "module",
  "scripts": {
    "predev": "pnpm cf-typegen",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "d1:migrate": "wrangler d1 migrations apply loop",
    "db:migrate": "node --env-file=.dev.vars node_modules/node-pg-migrate/bin/node-pg-migrate.js up -m db/migrations -d DATABASE_URL_ADMIN",
    "db:migrate:down": "node --env-file=.dev.vars node_modules/node-pg-migrate/bin/node-pg-migrate.js down -m db/migrations -d DATABASE_URL_ADMIN",
    "db:migrate:new": "node-pg-migrate create -m db/migrations -j sql",
    "eval": "node --env-file=.dev.vars eval/run.ts",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@neondatabase/serverless": "^1.1.0",
    "agents": "^0.15.0",
    "ai": "^6.0.197",
    "hono": "^4.12.24",
    "pgsql-ast-parser": "^12.0.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  }
}
