# Production build config for `pnpm seller run deploy`. Copy to .env.production
# (gitignored). `astro build` loads .env.production in production mode and bakes
# these PUBLIC_ values into the bundle.

# The shop's Neon Auth base URL (same managed service as dev).
PUBLIC_NEON_AUTH_URL=https://<project>.neonauth.<region>.aws.neon.tech/neondb/auth

# The DEPLOYED worker origin — must be the same instance the WhatsApp webhook
# hits, so the dashboard's ShopAgent WebSocket receives live order pushes.
PUBLIC_WORKER_URL=https://<your-worker>.workers.dev
