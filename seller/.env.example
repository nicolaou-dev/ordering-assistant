# Client config baked into the build (PUBLIC_ prefix → exposed to the browser).
# Copy to .env and fill in.

# Shop's Neon Auth base URL — what Neon hands you as VITE_NEON_AUTH_URL.
PUBLIC_NEON_AUTH_URL=https://<project>.neonauth.<region>.aws.neon.tech/neondb/auth

# Worker API origin the seller app calls (e.g. http://localhost:8787 in dev).
PUBLIC_WORKER_URL=http://localhost:8787

# PostHog analytics. Project API key and host from PostHog → Settings → Project.
# Host is https://us.i.posthog.com or https://eu.i.posthog.com by region.
PUBLIC_POSTHOG_KEY=phc_...
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
